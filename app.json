{
  "expo": {
    "name": "StickerScan",
    "slug": "stickerscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stickerscan.mvp",
      "infoPlist": {
        "NSCameraUsageDescription": "Necessário para escanear figurinhas da Copa"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.stickerscan.mvp",
      "permissions": ["android.permission.CAMERA"]
    },
    "plugins": ["expo-router", "expo-camera"],
    "scheme": "stickerscan",
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
